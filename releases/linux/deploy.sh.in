#!/bin/bash

# This script is expected to be executed from within release/linux
# The script will be configured by the python script.

OUTPUT_DIRECTORY_NAME=${OutputDirectoryName}
OUTPUT_FILE_BASENAME=${OutputFileBasename}

# Create Release-Path and subdirs

mkdir -p $OUTPUT_DIRECTORY_NAME &&
mkdir -p $OUTPUT_DIRECTORY_NAME/bin &&
mkdir -p $OUTPUT_DIRECTORY_NAME/resources &&
mkdir -p $OUTPUT_DIRECTORY_NAME/resources/translations &&
mkdir -p $OUTPUT_DIRECTORY_NAME/resources/examples &&
mkdir -p $OUTPUT_DIRECTORY_NAME/doc &&

# Copy executable

cp ../../bin/release/mastersim $OUTPUT_DIRECTORY_NAME/bin &&
cp ../../bin/release/mastersim-gui $OUTPUT_DIRECTORY_NAME/bin &&

# Copy translations

cp ../../MasterSimulatorUI/resources/translations/mastersim-gui_de.qm $OUTPUT_DIRECTORY_NAME/resources/translations/ &&

# Copy documentation

cp ../../doc/manual/MasterSim_manual_de.pdf $OUTPUT_DIRECTORY_NAME/doc/ &&
cp ../../doc/manual/MasterSim_manual_en.pdf $OUTPUT_DIRECTORY_NAME/doc/ &&
cp readme.txt $OUTPUT_DIRECTORY_NAME/bin &&

# Copy icons

cp ../../MasterSimulatorUI/resources/gfx/logo/* $OUTPUT_DIRECTORY_NAME/resources/ &&

# Copy examples files

cp -R ../../data/examples/linux64/* $OUTPUT_DIRECTORY_NAME/resources/examples &&

# Copy auxilliary files

cp ../../LICENSE $OUTPUT_DIRECTORY_NAME/resources/LICENSE &&

${CreateArchive}

